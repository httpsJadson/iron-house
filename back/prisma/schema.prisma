generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(uuid())
  nome              String
  email             String        @unique
  password          String
  peso              Float?
  altura            Float?
  statusPagamento   Status        @default(PENDENTE)
  stripeId          String?
  planId            String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  plan              Plan?         @relation(fields: [planId], references: [id])
  treinosRealizados WorkoutLog[]
  fichas            WorkoutPlan[]
}

model Plan {
  id            String  @id @default(uuid())
  name          String
  price         Decimal @db.Decimal(10, 2)
  daysPerWeek   Int
  hasTreadmill  Boolean @default(false)
  hasGym        Boolean @default(true)
  gatewayPlanId String?
  hasBoxy       Boolean @default(false)
  hasSwimming   Boolean @default(false)
  User          User[]
}

model Exercise {
  id            Int        @id @default(autoincrement())
  nome          String
  met           Float
  grupoMuscular String
  isTreadmill   Boolean    @default(false)
  logs          LogItem[]
  itemsFicha    PlanItem[]
}

model WorkoutPlan {
  id        String     @id @default(uuid())
  nome      String
  userId    String
  ativo     Boolean    @default(true)
  createdAt DateTime   @default(now())
  items     PlanItem[]
  user      User       @relation(fields: [userId], references: [id])
}

model PlanItem {
  id          Int         @id @default(autoincrement())
  planId      String
  exerciseId  Int
  series      Int
  reps        Int
  descansoSec Int
  exercise    Exercise    @relation(fields: [exerciseId], references: [id])
  plan        WorkoutPlan @relation(fields: [planId], references: [id])
}

model WorkoutLog {
  id          String    @id @default(uuid())
  userId      String
  inicio      DateTime  @default(now())
  fim         DateTime?
  duracaoMin  Int?
  calorias    Float?
  volumeTotal Float?
  items       LogItem[]
  user        User      @relation(fields: [userId], references: [id])
}

model LogItem {
  id         Int        @id @default(autoincrement())
  logId      String
  exerciseId Int
  carga      Float
  repsFeitas Int
  exercise   Exercise   @relation(fields: [exerciseId], references: [id])
  log        WorkoutLog @relation(fields: [logId], references: [id])
}

enum Status {
  ATIVO
  INADIMPLENTE
  PENDENTE
}
